KOUOJ_SECRET_KEY=dev-only-secret-key
KOUOJ_DEBUG=1
KOUOJ_ALLOWED_HOSTS=127.0.0.1,localhost

KOUOJ_DB_NAME=kouoj
KOUOJ_DB_USER=root
KOUOJ_DB_PASSWORD=
KOUOJ_DB_HOST=localhost
KOUOJ_DB_PORT=3306

KOUOJ_CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

KOUOJ_JUDGE_PYTHON=python

# Tavily 网页搜索配置，用于后端 agent 查找外部题解资料。
KOUOJ_TAVILY_API_KEY=
KOUOJ_TAVILY_MAX_RESULTS=5
KOUOJ_TAVILY_SEARCH_DEPTH=basic

# AI 模型配置，按 OpenAI-compatible 接口预留。
KOUOJ_AI_MODEL_PROVIDER=openai-compatible
KOUOJ_AI_MODEL_BASE_URL=
KOUOJ_AI_MODEL_API_KEY=
KOUOJ_AI_MODEL_NAME=
KOUOJ_AI_MODEL_TEMPERATURE=0
KOUOJ_AI_MODEL_TIMEOUT=30
